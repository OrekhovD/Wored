# ═══════════════════════════════════════════════════════════
# HTX Trading Bot — Environment Configuration
# Версия: 1.1 | 18.04.2026
# ⚠️  НИКОГДА не коммитить этот файл в git
# ═══════════════════════════════════════════════════════════

# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_TOKEN=                        # от @BotFather — НОВЫЙ после ротации!
TELEGRAM_ADMIN_ID=                     # твой Telegram user_id

# ─── HTX Exchange ───────────────────────────────────────────
# ⚠️  Пересоздать после утечки!
HTX_ACCESS_KEY=                        # HMAC Access Key
HTX_SECRET_KEY=                        # Secret Key
HTX_PASSPHRASE=                        # если требуется (v2 API)

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=trading
POSTGRES_USER=bot
POSTGRES_PASSWORD=generate_strong_password_here
DATABASE_URL=postgresql+asyncpg://bot:generate_strong_password_here@postgres:5432/trading

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── AI Models ──────────────────────────────────────────────

# Qwen / Alibaba DashScope
# Endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=                     # sk-xxxx (пересоздать!)
# Модели с бесплатной квотой на аккаунте:
# qwen3.6-plus (505k/1M), qwen3-max (1M/1M), qwen3.5-plus (985k/1M)

# GLM / ZhipuAI BigModel
# Endpoint: https://open.bigmodel.cn/api/paas/v4/
GLM_API_KEY=                           # xxxx.xxxx формат (пересоздать!)
GLM_MODEL=glm-4-plus                   # ⚠️ Уточнить актуальный model string

# MiniMax / via NVIDIA NIM
# ⚠️ Ключ nvapi-... → endpoint NVIDIA NIM, не нативный MiniMax
# Endpoint: https://integrate.api.nvidia.com/v1
MINIMAX_API_KEY=                       # nvapi-xxxx (пересоздать!)
# Уточнить точный model name в каталоге: https://build.nvidia.com/explore/discover

# Google AI Studio (Gemini) — БОНУС, ключ AQ.Ab8...
# Endpoint: https://generativelanguage.googleapis.com/v1beta/openai/
GOOGLE_API_KEY=                        # AQ.xxxx (пересоздать!)
GEMINI_MODEL=gemini-2.0-flash

# Perplexity Sonar (если есть ключ — добавить)
PERPLEXITY_API_KEY=                    # pplx-xxxx

# ─── Trading Config ─────────────────────────────────────────
WATCHLIST=btcusdt,ethusdt,solusdt,bnbusdt,xrpusdt
ALERT_SPIKE_THRESHOLD=3.0              # % за 15 минут
DEFAULT_AI_MODEL=qwen3.6-plus         # модель по умолчанию
LOG_LEVEL=INFO
TIMEZONE_OFFSET_HOURS=7               # Thailand UTC+7

# ─── Briefing Schedule ──────────────────────────────────────
BRIEFING_HOUR_UTC=1                    # 08:00 МСК = 01:00 UTC (для Thai UTC+7: 08:00 local = 01:00 UTC)
