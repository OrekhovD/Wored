# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=your_admin_telegram_id_here

# HTX (read-only)
HTX_API_KEY=your_htx_api_key_here
HTX_API_SECRET=your_htx_api_secret_here
HTX_BASE_URL=https://api.huobi.pro

# Database
SQLITE_DB_URL=sqlite+aiosqlite:///./data/hytergram.db

# AI Providers
DASHSCOPE_API_KEY=your_dashscope_api_key_here
NVAPI_API_KEY=your_nvapi_key_here
GLM5_API_KEY=your_glm5_api_key_here
AI_STUDIO_API_KEY=your_ai_studio_api_key_here

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Configuration
DEFAULT_ROUTING_MODE=free_only
LOG_LEVEL=INFO
CONTEXT_MAX_TOKENS=4000
QUOTA_WARNING_THRESHOLD_PCT=20.0
QUOTA_CRITICAL_THRESHOLD_PCT=10.0
QUOTA_HARD_STOP_THRESHOLD_PCT=3.0
REQUEST_TIMEOUT_SECONDS=120
FALLBACK_RETRY_COUNT=2
CACHING_ENABLED=true
CACHE_TTL_SECONDS=60
TELEGRAM_POLL_TIMEOUT=10