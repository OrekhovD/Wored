# Root runtime configuration for D:\WORED
# Copy this file to .env and replace placeholder values.

# Telegram
TELEGRAM_TOKEN=1234567890:replace_with_bot_token
TELEGRAM_ADMIN_ID=123456789

# AI providers
# webui Prediction Lab uses the same keys.
# If a key is empty, the corresponding model stays offline.
GLM_API_KEY=replace_with_zhipu_api_key
GLM_MODEL=glm-5.1
DASHSCOPE_API_KEY=
WORKER_QWEN_MODEL=qwen3.6-flash
WORKER_QWEN_FALLBACKS=qwen3.5-flash,qwen-flash
WORKER_GLM_FALLBACK_MODEL=glm-4-flash
WORKER_GEMINI_FALLBACK_MODEL=gemini-3-flash-preview
ANALYST_QWEN_MODEL=qwen3.6-35b-a3b
ANALYST_QWEN_FALLBACKS=qwen3.6-27b
ANALYST_GLM_FALLBACK_MODEL=glm-5.1
PREMIUM_QWEN_MODEL=qwen3.6-27b
PREMIUM_QWEN_FALLBACKS=qwen3.6-35b-a3b
PREMIUM_GLM_FALLBACK_MODEL=glm-5.1
GOOGLE_API_KEY=
MINIMAX_API_KEY=

# Market runtime
WATCHLIST=btcusdt,ethusdt
ALERT_SPIKE_THRESHOLD=3.0
LOG_LEVEL=INFO
WEBUI_PORT=8080
HTX_REST_URL=https://api.huobi.pro
WEBUI_AUTH_ENABLED=true
WEBUI_ADMIN_USERNAME=admin
# Run `python scripts/generate_secrets.py` to generate strong values
WEBUI_ADMIN_PASSWORD=replace_with_generated_password
WEBUI_SESSION_SECRET=replace_with_generated_secret
WEBUI_INTERNAL_URL=http://webui:8000
WEBUI_PUBLIC_BASE_URL=http://localhost:8080
WEBUI_INTERNAL_TOKEN=

# Storage
POSTGRES_USER=bot
# Run `python scripts/generate_secrets.py` to generate secure password
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=trading
DATABASE_URL=postgresql+asyncpg://bot:change_me_strong_password@postgres:5432/trading
REDIS_URL=redis://redis:6379/0

# Legacy / research variables that are not required by the active runtime path.
PERPLEXITY_API_KEY=
DEFAULT_AI_MODEL=
BRIEFING_HOUR_UTC=1
TIMEZONE_OFFSET_HOURS=7
HTX_ACCESS_KEY=
HTX_SECRET_KEY=
HTX_PASSPHRASE=
